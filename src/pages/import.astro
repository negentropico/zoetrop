---
/**
 * Import Hub Page
 *
 * Choose data source to import from.
 */
import Layout from '../layouts/Layout.astro';
---

<Layout title="Import Data">
  <div class="max-w-2xl mx-auto py-8 px-4">
    <nav class="mb-6">
      <a
        href="/"
        class="inline-flex items-center text-sm font-medium text-gray-500 hover:text-gray-700"
      >
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Dashboard
      </a>
    </nav>

    <div class="text-center mb-8">
      <h1 class="text-2xl font-bold text-gray-900 mb-2">Import Health Data</h1>
      <p class="text-gray-600">Choose a data source to import metrics from.</p>
    </div>

    <div class="grid gap-4">
      <!-- WHOOP Import -->
      <a
        href="/import/whoop"
        class="group bg-white rounded-lg shadow-sm border border-gray-200 p-6 hover:border-blue-300 hover:shadow-md transition-all"
      >
        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 p-3 bg-blue-50 rounded-lg group-hover:bg-blue-100 transition-colors">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
            </svg>
          </div>
          <div class="flex-1">
            <h2 class="text-lg font-semibold text-gray-900 group-hover:text-blue-600 transition-colors">
              WHOOP Data
            </h2>
            <p class="text-sm text-gray-600 mt-1">
              Import HRV, recovery, sleep, and other physiological metrics.
            </p>
            <p class="text-xs text-gray-500 mt-2">
              Supports CSV exports and JSON analysis reports.
            </p>
          </div>
          <div class="flex-shrink-0 self-center">
            <svg class="w-5 h-5 text-gray-400 group-hover:text-blue-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </div>
      </a>

      <!-- Vault Import -->
      <a
        href="/import/vault"
        class="group bg-white rounded-lg shadow-sm border border-gray-200 p-6 hover:border-purple-300 hover:shadow-md transition-all"
      >
        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 p-3 bg-purple-50 rounded-lg group-hover:bg-purple-100 transition-colors">
            <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <div class="flex-1">
            <h2 class="text-lg font-semibold text-gray-900 group-hover:text-purple-600 transition-colors">
              Obsidian Vault
            </h2>
            <p class="text-sm text-gray-600 mt-1">
              Import blood work, body composition, and other health metrics.
            </p>
            <p class="text-xs text-gray-500 mt-2">
              Parses markdown tables from your vault files.
            </p>
          </div>
          <div class="flex-shrink-0 self-center">
            <svg class="w-5 h-5 text-gray-400 group-hover:text-purple-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </div>
      </a>

      <!-- Seed Data (Initial Profile) -->
      <a
        href="/import/seed"
        class="group bg-white rounded-lg shadow-sm border border-gray-200 p-6 hover:border-emerald-300 hover:shadow-md transition-all"
      >
        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 p-3 bg-emerald-50 rounded-lg group-hover:bg-emerald-100 transition-colors">
            <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4" />
            </svg>
          </div>
          <div class="flex-1">
            <h2 class="text-lg font-semibold text-gray-900 group-hover:text-emerald-600 transition-colors">
              Initial Profile Data
            </h2>
            <p class="text-sm text-gray-600 mt-1">
              Load pre-generated seed data for first-time setup.
            </p>
            <p class="text-xs text-gray-500 mt-2">
              Includes 2,850 metrics from WHOOP, blood work, and DEXA scans.
            </p>
          </div>
          <div class="flex-shrink-0 self-center">
            <svg class="w-5 h-5 text-gray-400 group-hover:text-emerald-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </div>
      </a>
    </div>
  </div>
</Layout>
