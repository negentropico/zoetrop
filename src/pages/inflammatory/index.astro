---
/**
 * Inflammatory Category Page
 */
import Layout from '../../layouts/Layout.astro';
import CategoryPageView from '@/components/categories/CategoryPageView';
---

<Layout title="Inflammatory">
  <div class="min-h-screen">
    <!-- Header -->
    <header class="bg-blue-600 text-white py-4 shadow-md">
      <div class="container mx-auto px-4">
        <h1 class="text-2xl font-semibold">Wellness Tracker</h1>
        <p class="text-blue-100 text-sm mt-1">Inflammatory - hs-CRP, homocysteine</p>
      </div>
    </header>

    <!-- Main Content -->
    <main class="container mx-auto px-4 py-6">
      <CategoryPageView client:load categoryId="inflammatory" />
    </main>
  </div>
</Layout>
