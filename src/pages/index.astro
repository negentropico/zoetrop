---
import Layout from '../layouts/Layout.astro';
import AllMetricsView from '../components/categories/AllMetricsView';
---

<Layout title="Wellness Tracker">
  <div class="min-h-screen flex flex-col">
    <!-- Header -->
    <header class="bg-blue-600 text-white py-4 shadow-md">
      <div class="container mx-auto px-4 flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-semibold">Wellness Tracker</h1>
          <p class="text-blue-100 text-sm mt-1">Comprehensive health metrics dashboard</p>
        </div>
        <a
          href="/import/"
          class="px-4 py-2 bg-white/20 hover:bg-white/30 rounded-lg text-sm font-medium transition-colors"
        >
          Import Data
        </a>
      </div>
    </header>

    <!-- Main Content - Single View with Collapsible Sections -->
    <main class="flex-1 container mx-auto px-4 py-6">
      <AllMetricsView client:load />
    </main>

    <!-- Footer -->
    <footer class="py-4 text-center text-xs text-gray-500">
      <p>Wellness Tracker v0.3.0 | Single View Dashboard</p>
    </footer>
  </div>
</Layout>
