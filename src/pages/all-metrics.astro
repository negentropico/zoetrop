---
/**
 * All Metrics Page
 *
 * Single unified view of all metrics across all categories.
 */
import Layout from '../layouts/Layout.astro';
import AllMetricsView from '@/components/categories/AllMetricsView';
---

<Layout title="All Metrics">
  <div class="min-h-screen">
    <!-- Header -->
    <header class="bg-blue-600 text-white py-4 shadow-md">
      <div class="container mx-auto px-4">
        <h1 class="text-2xl font-semibold">Wellness Tracker</h1>
        <p class="text-blue-100 text-sm mt-1">All Metrics - Complete health data view</p>
      </div>
    </header>

    <!-- Navigation -->
    <nav class="bg-white border-b border-gray-200 sticky top-0 z-10">
      <div class="container mx-auto px-4">
        <div class="flex items-center gap-1 overflow-x-auto py-2">
          <a
            href="/"
            class="px-3 py-2 rounded-full text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-100 transition-colors whitespace-nowrap"
          >
            Dashboard
          </a>
          <a
            href="/all-metrics"
            class="px-3 py-2 rounded-full text-sm font-medium bg-blue-600 text-white whitespace-nowrap"
          >
            All Metrics
          </a>
          <a
            href="/vitamins"
            class="px-3 py-2 rounded-full text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-100 transition-colors whitespace-nowrap"
          >
            Vitamins
          </a>
          <a
            href="/minerals"
            class="px-3 py-2 rounded-full text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-100 transition-colors whitespace-nowrap"
          >
            Minerals
          </a>
          <a
            href="/inflammatory"
            class="px-3 py-2 rounded-full text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-100 transition-colors whitespace-nowrap"
          >
            Inflammatory
          </a>
          <a
            href="/metabolic"
            class="px-3 py-2 rounded-full text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-100 transition-colors whitespace-nowrap"
          >
            Metabolic
          </a>
          <a
            href="/hormones"
            class="px-3 py-2 rounded-full text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-100 transition-colors whitespace-nowrap"
          >
            Hormones
          </a>
          <a
            href="/autonomic"
            class="px-3 py-2 rounded-full text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-100 transition-colors whitespace-nowrap"
          >
            Autonomic
          </a>
          <a
            href="/body-composition"
            class="px-3 py-2 rounded-full text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-100 transition-colors whitespace-nowrap"
          >
            Body Composition
          </a>
          <a
            href="/lipids"
            class="px-3 py-2 rounded-full text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-100 transition-colors whitespace-nowrap"
          >
            Lipids
          </a>
          <a
            href="/hematology"
            class="px-3 py-2 rounded-full text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-100 transition-colors whitespace-nowrap"
          >
            Hematology
          </a>
          <a
            href="/import"
            class="ml-auto px-3 py-2 rounded-full text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-100 transition-colors whitespace-nowrap"
          >
            Import Data
          </a>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="container mx-auto px-4 py-6">
      <AllMetricsView client:load />
    </main>

    <!-- Footer -->
    <footer class="bg-gray-100 border-t border-gray-200 py-4 mt-8">
      <div class="container mx-auto px-4 text-center text-sm text-gray-600">
        Wellness Tracker v0.2.0 | Phase 2 MVP Dashboard
      </div>
    </footer>
  </div>
</Layout>
