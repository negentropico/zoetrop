---
/**
 * BaseLayout Component
 *
 * Base layout with header navigation.
 * Use this for pages that need the full navigation header.
 */
import '../styles/global.css';
import Header from '@/components/layout/Header';

interface Props {
  title: string;
  description?: string;
  currentPath?: string;
  showHeader?: boolean;
}

const {
  title,
  description = 'Comprehensive wellness tracking dashboard',
  currentPath = Astro.url.pathname,
  showHeader = true,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title} | Wellness Tracker</title>
  </head>
  <body class="min-h-screen bg-surface">
    {showHeader && <Header client:load currentPath={currentPath} />}
    <main class="container mx-auto px-4 py-6">
      <slot />
    </main>
    <footer class="mt-auto py-4 text-center text-xs text-gray-500">
      <p>Wellness Tracker v0.2.0 | Phase 2 MVP Dashboard</p>
    </footer>
  </body>
</html>

<style is:global>
  html {
    font-family: 'Inter', system-ui, sans-serif;
    scroll-behavior: smooth;
  }
</style>
