# Zoetrop — environment variables
# ---------------------------------------------------------------------------
# Copy this file to `.env` (git-ignored) and fill in the real values.
# These are what I need for DB migrations, the Phase 1 auth/RLS spike, and
# local dev.
#
# WHERE THIS FILE IS LOADED FROM:
#   The app + tooling live in `remix-app/`. Vite resolves env vars from
#   `remix-app/` (not the repo root), and drizzle-kit/the spike read
#   `process.env`. After filling the root `.env`, make it visible to the
#   tooling with EITHER:
#       ln -s ../.env remix-app/.env          # symlink (recommended)
#   OR just keep the filled file at `remix-app/.env`.
#   Both `.env` and `remix-app/.env` are already git-ignored.
#   (Tell me once it's filled and I can create the symlink for you.)
#
# Use BARE connection URLs (postgresql://...), NOT a `psql '...'` wrapper.
# ===========================================================================

# ── Zoetrop Neon Postgres (production) ─────────────────────────────────────
# Read by remix-app/app/lib/db.server.ts and remix-app/drizzle.config.ts as:
#   process.env.NETLIFY_DATABASE_URL || process.env.DATABASE_URL
# On Netlify these are injected by the Neon extension; locally set DATABASE_URL.
# Pooled connection (for the app / general queries):
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Direct / unpooled connection — used for schema migrations (drizzle-kit migrate).
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Optional: mirror the exact Netlify-injected names for prod parity. If set,
# these take precedence over DATABASE_URL in the app/tooling.
# NETLIFY_DATABASE_URL=
# NETLIFY_DATABASE_URL_UNPOOLED=

# ── Phase 1 · Plan 01-03 — Better-Auth ↔ Neon pg_session_jwt RLS spike ─────
# THROWAWAY only. Must be a DISPOSABLE Neon branch with NO production PHI —
# never the production DB above. Create a branch (Neon console or
# `neonctl branches create`), paste its connection string here, and delete the
# branch after the spike verdict is recorded.
SPIKE_DATABASE_URL=postgresql://USER:PASSWORD@SPIKE-BRANCH-HOST.REGION.aws.neon.tech/neondb?sslmode=require

# Better-Auth — spike-scoped in Phase 1 (Phase 3 promotes it to a real dep).
# BETTER_AUTH_SECRET signs the JWTs the jwt() plugin issues.
#   Generate one with:  openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-output-of-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# Optional: a Neon API key lets me create AND tear down the disposable spike
# branch (and any future branches) directly, instead of you doing it in the
# Neon console. Create at https://console.neon.tech/app/settings/api-keys
# NEON_API_KEY=
